  left: 16px;
  display: flex;
  gap: 8px;
}

.participant-badge-name {
  font-size: 0.75rem;
  font-weight: 600;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  padding: 4px 10px;
  border-radius: 8px;
  backdrop-filter: blur(4px);
}

.participant-badge-muted {
  font-size: 0.75rem;
  font-weight: 600;
  background: rgba(239, 68, 68, 0.75);
  color: white;
  padding: 4px 10px;
  border-radius: 8px;
