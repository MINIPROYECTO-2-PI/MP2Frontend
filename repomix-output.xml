/* Grid layout for room main body */
.room-grid {
  flex-grow: 1;
  display: grid;
  grid-template-columns: 1fr 360px;
  position: relative;
  z-index: 10;
  box-sizing: border-box;
}

/* Stage Area (Videos / Presentations) */
.room-stage {
  padding: 28px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  box-sizing: border-box;
  overflow-y: auto;
}

.room-video-container {
  flex-grow: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-video-card {
  width: 100%;
  max-width: 720px;
  aspect-ratio: 16/9;
  border-radius: 24px;
  background: rgba(15, 12, 32, 0.45);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  position: relative;
  overflow: hidden;
  box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
}

.room-video-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
}

.room-video-avatar {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  object-cover: cover;
  border: 3px solid rgba(99, 102, 241, 0.5);
  box-shadow: 0 0 24px rgba(99, 102, 241, 0.3);
}

.room-video-avatar-fallback {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: 750;
  border: 3px solid rgba(99, 102, 241, 0.5);
  box-shadow: 0 0 24px rgba(99, 102, 241, 0.3);
}

.room-video-name {
  font-size: 1.05rem;
  font-weight: 700;
  color: white;
}

.room-status-sub {
  font-size: 0.8rem;
  color: rgba(255, 255, 255, 0.4);
  background: rgba(0, 0, 0, 0.25);
  padding: 4px 12px;
  border-radius: 8px;
}

.room-video-active-feed {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  background: #111019;
}

.room-avatar-glowing {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: rgba(99, 102, 241, 0.1);
  border: 2px dashed rgba(99, 102, 241, 0.6);
