.profile-nav-title { font-size:1.1rem; font-weight:700; background:linear-gradient(to right,#a5b4fc,#c4b5fd); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }

.profile-main { position:relative; z-index:10; flex:1; display:flex; align-items:flex-start; justify-content:center; padding:40px 20px; }
.profile-container { width:100%; max-width:640px; display:flex; flex-direction:column; gap:20px; animation:auth-slide-up .6s cubic-bezier(.16,1,.3,1); }

.profile-alert { display:flex; align-items:center; gap:10px; padding:14px 18px; border-radius:14px; font-size:.85rem; font-weight:600; animation:auth-alert-slide-in .4s cubic-bezier(.175,.885,.32,1.275); }
.profile-alert--success { background:rgba(16,185,129,.14); border:1px solid rgba(16,185,129,.25); color:#a7f3d0; }
.profile-alert--error { background:rgba(239,68,68,.14); border:1px solid rgba(239,68,68,.25); color:#fecaca; }

.profile-card { background:rgba(15,12,32,.55); backdrop-filter:blur(32px) saturate(2); border:1px solid rgba(255,255,255,.1); border-radius:28px; overflow:hidden; box-shadow:0 30px 70px -12px rgba(0,0,0,.6),0 0 80px -10px rgba(99,102,241,.2); }

.profile-avatar-section { display:flex; align-items:center; gap:24px; padding:36px 40px; }
.profile-avatar-wrapper { position:relative; flex-shrink:0; }
.profile-avatar-svg, .profile-avatar-img, .profile-avatar-fallback { width:80px; height:80px; border-radius:50%; border:3px solid rgba(99,102,241,.5); object-fit:cover; }
.profile-avatar-svg svg { width:80px; height:80px; border-radius:50%; }
.profile-avatar-fallback { background:linear-gradient(135deg,#4f46e5,#7c3aed); display:flex; align-items:center; justify-content:center; color:white; }
.profile-avatar-badge { position:absolute; bottom:2px; right:2px; width:24px; height:24px; border-radius:50%; background:linear-gradient(135deg,#4f46e5,#ec4899); display:flex; align-items:center; justify-content:center; color:white; border:2px solid #0f0c20; }
.profile-avatar-info { display:flex; flex-direction:column; gap:4px; }
.profile-display-name { font-size:1.35rem; font-weight:750; color:white; margin:0; }
.profile-username-tag { font-size:.85rem; color:#a5b4fc; font-weight:500; }
.profile-provider-badge { font-size:.7rem; padding:3px 10px; border-radius:99px; background:rgba(99,102,241,.15); border:1px solid rgba(99,102,241,.25); color:#c7d2fe; font-weight:600; width:fit-content; margin-top:4px; }

.profile-divider { height:1px; background:rgba(255,255,255,.07); margin:0; }

.profile-fields { padding:28px 40px; display:flex; flex-direction:column; gap:20px; }
.profile-field { display:flex; flex-direction:column; gap:6px; }
.profile-field-label { display:flex; align-items:center; gap:6px; font-size:.8rem; font-weight:600; color:rgba(255,255,255,.6); text-transform:uppercase; letter-spacing:.04em; }
.profile-field-value { font-size:1rem; font-weight:500; color:rgba(255,255,255,.9); padding:12px 16px; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.06); border-radius:12px; }
.profile-field-input { font-size:1rem; font-weight:500; color:white; padding:12px 16px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:12px; outline:none; transition:all .25s; }
.profile-field-input:focus { border-color:rgba(99,102,241,.7); box-shadow:0 0 0 2px rgba(99,102,241,.4),0 0 16px rgba(99,102,241,.2); background:rgba(255,255,255,.08); }

.profile-actions { padding:20px 40px 32px; }
.profile-edit-actions, .profile-view-actions { display:flex; gap:12px; flex-wrap:wrap; }

.profile-btn { display:inline-flex; align-items:center; gap:8px; padding:12px 20px; border-radius:12px; font-size:.875rem; font-weight:600; border:none; cursor:pointer; transition:all .25s; }
.profile-btn:disabled { opacity:.5; cursor:not-allowed; }
.profile-btn--edit { background:linear-gradient(135deg,#4f46e5,#7c3aed); color:white; box-shadow:0 4px 16px rgba(99,102,241,.35); }
.profile-btn--edit:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 6px 24px rgba(99,102,241,.5); }
.profile-btn--save { background:linear-gradient(135deg,#059669,#10b981); color:white; box-shadow:0 4px 16px rgba(16,185,129,.35); }
.profile-btn--save:hover:not(:disabled) { transform:translateY(-2px); box-shadow:0 6px 24px rgba(16,185,129,.5); }
.profile-btn--cancel { background:rgba(255,255,255,.08); color:rgba(255,255,255,.7); border:1px solid rgba(255,255,255,.12); }
.profile-btn--cancel:hover:not(:disabled) { background:rgba(255,255,255,.14); color:white; }
.profile-btn--delete { background:rgba(239,68,68,.12); color:#fca5a5; border:1px solid rgba(239,68,68,.2); }
.profile-btn--delete:hover:not(:disabled) { background:rgba(239,68,68,.2); color:#fecaca; transform:translateY(-1px); }
.profile-btn-spinner { animation:spin 1s linear infinite; }

/* Delete Modal */
.profile-modal-overlay { position:fixed; inset:0; z-index:100; background:rgba(0,0,0,.7); backdrop-filter:blur(8px); display:flex; align-items:center; justify-content:center; padding:20px; animation:fadeIn .2s ease-out; }
.profile-modal { background:rgba(15,12,32,.95); backdrop-filter:blur(32px); border:1px solid rgba(239,68,68,.2); border-radius:24px; padding:40px; max-width:480px; width:100%; text-align:center; box-shadow:0 30px 70px rgba(0,0,0,.6),0 0 60px rgba(239,68,68,.15); animation:auth-slide-up .4s cubic-bezier(.16,1,.3,1); }
.profile-modal-icon { color:#f87171; margin-bottom:16px; animation:pulse 2s infinite; }
@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:.6;} }
.profile-modal-title { font-size:1.4rem; font-weight:750; color:#fecaca; margin:0 0 12px; }
.profile-modal-desc { font-size:.9rem; color:rgba(255,255,255,.6); line-height:1.6; margin-bottom:24px; }
.profile-modal-confirm { text-align:left; margin-bottom:24px; }
.profile-modal-label { font-size:.8rem; color:rgba(255,255,255,.5); font-weight:600; display:block; margin-bottom:8px; }
.profile-modal-input { width:100%; padding:12px 16px; background:rgba(255,255,255,.06); border:1px solid rgba(239,68,68,.2); border-radius:12px; color:white; font-size:1rem; outline:none; transition:all .25s; box-sizing:border-box; }
.profile-modal-input:focus { border-color:rgba(239,68,68,.5); box-shadow:0 0 0 2px rgba(239,68,68,.3); }
.profile-modal-actions { display:flex; flex-direction:column; gap:10px; }
.profile-btn--confirm-delete { background:linear-gradient(135deg,#dc2626,#b91c1c); color:white; box-shadow:0 4px 16px rgba(220,38,38,.35); justify-content:center; }
.profile-btn--confirm-delete:hover:not(:disabled) { box-shadow:0 6px 24px rgba(220,38,38,.5); }
.profile-btn--cancel-modal { background:rgba(255,255,255,.08); color:rgba(255,255,255,.7); border:1px solid rgba(255,255,255,.1); justify-content:center; }

/* ═══════════════════════════════════════════════ */
/*  DASHBOARD PAGE — US-06                         */
/* ═══════════════════════════════════════════════ */

.dashboard-page { position:relative; min-height:100dvh; display:flex; flex-direction:column; overflow:hidden; background:#05051a; color:white; font-family:'Geist Variable',sans-serif; }

.dashboard-nav { position:relative; z-index:10; backdrop-filter:blur(16px); background:rgba(255,255,255,.03); border-bottom:1px solid rgba(255,255,255,.08); padding:12px 24px; }
.dashboard-nav-inner { max-width:1100px; margin:0 auto; display:flex; align-items:center; justify-content:space-between; }
.dashboard-nav-left { display:flex; align-items:center; gap:10px; }
.dashboard-nav-logo { width:40px; height:40px; border-radius:12px; background:linear-gradient(135deg,#4f46e5,#7c3aed,#ec4899); display:flex; align-items:center; justify-content:center; color:white; box-shadow:0 4px 16px rgba(99,102,241,.4); }
.dashboard-nav-title { font-size:1.15rem; font-weight:750; background:linear-gradient(to right,#c7d2fe,#e9d5ff); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.dashboard-nav-right { display:flex; align-items:center; gap:12px; }

.dashboard-profile-chip { display:flex; align-items:center; gap:10px; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); border-radius:99px; padding:6px 16px 6px 6px; cursor:pointer; transition:all .2s; color:white; }
.dashboard-profile-chip:hover { background:rgba(255,255,255,.1); border-color:rgba(255,255,255,.18); }
.dashboard-profile-avatar { width:32px; height:32px; border-radius:50%; object-fit:cover; border:2px solid rgba(99,102,241,.4); }
.dashboard-profile-avatar-fallback { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,#4f46e5,#7c3aed); display:flex; align-items:center; justify-content:center; font-size:.75rem; font-weight:700; border:2px solid rgba(99,102,241,.4); }
.dashboard-profile-info { display:flex; flex-direction:column; text-align:left; }
.dashboard-profile-name { font-size:.75rem; font-weight:600; color:rgba(255,255,255,.9); line-height:1.2; }
.dashboard-profile-tag { font-size:.65rem; color:#a5b4fc; }

.dashboard-logout-btn { display:flex; align-items:center; gap:6px; font-size:.75rem; font-weight:600; color:#fca5a5; background:rgba(239,68,68,.1); border:1px solid rgba(239,68,68,.2); border-radius:10px; padding:8px 14px; cursor:pointer; transition:all .2s; }
.dashboard-logout-btn:hover { background:rgba(239,68,68,.2); color:#fecaca; }

.dashboard-main { position:relative; z-index:10; flex:1; padding:40px 24px; }
.dashboard-container { max-width:1100px; margin:0 auto; animation:auth-slide-up .6s cubic-bezier(.16,1,.3,1); }

.dashboard-header { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:32px; gap:16px; flex-wrap:wrap; }
.dashboard-header-text { display:flex; flex-direction:column; gap:6px; }
.dashboard-title { display:flex; align-items:center; gap:12px; font-size:1.8rem; font-weight:800; margin:0; background:linear-gradient(to right,#fff,#c7d2fe); -webkit-background-clip:text; background-clip:text; -webkit-text-fill-color:transparent; }
.dashboard-subtitle { font-size:.95rem; color:rgba(255,255,255,.5); margin:0; }

.dashboard-create-btn { display:flex; align-items:center; gap:8px; padding:12px 24px; border-radius:14px; font-size:.9rem; font-weight:650; border:none; cursor:pointer; background:linear-gradient(135deg,#4f46e5,#7c3aed); color:white; box-shadow:0 4px 20px rgba(99,102,241,.4); transition:all .25s; }
.dashboard-create-btn:hover { transform:translateY(-2px); box-shadow:0 8px 28px rgba(99,102,241,.55); }
.dashboard-create-btn--large { padding:16px 32px; font-size:1rem; margin-top:12px; }

.dashboard-create-card { background:rgba(15,12,32,.6); backdrop-filter:blur(24px); border:1px solid rgba(99,102,241,.2); border-radius:20px; padding:28px 32px; margin-bottom:28px; animation:auth-slide-up .4s cubic-bezier(.16,1,.3,1); }
.dashboard-create-header { display:flex; align-items:center; gap:10px; margin-bottom:18px; font-size:1.05rem; font-weight:700; color:white; }
.dashboard-create-icon { color:#a5b4fc; }
.dashboard-create-form { display:flex; flex-direction:column; gap:16px; }
.dashboard-create-input-wrap { position:relative; }
.dashboard-create-input { width:100%; padding:14px 18px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12); border-radius:14px; color:white; font-size:1rem; outline:none; transition:all .25s; box-sizing:border-box; }
.dashboard-create-input:focus { border-color:rgba(99,102,241,.6); box-shadow:0 0 0 2px rgba(99,102,241,.35); }
.dashboard-create-input::placeholder { color:rgba(255,255,255,.3); }
.dashboard-create-counter { position:absolute; right:14px; top:50%; transform:translateY(-50%); font-size:.7rem; color:rgba(255,255,255,.3); }
.dashboard-create-actions { display:flex; gap:12px; }

/* Empty State */
.dashboard-loading { display:flex; flex-direction:column; align-items:center; gap:16px; padding:80px 20px; color:rgba(255,255,255,.5); }
.dashboard-empty { display:flex; flex-direction:column; align-items:center; text-align:center; padding:80px 20px; }
.dashboard-empty-icon { color:rgba(99,102,241,.4); margin-bottom:20px; animation:float-orb-1 6s ease-in-out infinite alternate; }
.dashboard-empty-title { font-size:1.6rem; font-weight:750; color:rgba(255,255,255,.8); margin:0 0 10px; }
.dashboard-empty-desc { font-size:.95rem; color:rgba(255,255,255,.45); max-width:400px; line-height:1.6; margin:0; }

/* Rooms Grid */
.dashboard-rooms-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:20px; }
.dashboard-room-card { background:rgba(15,12,32,.55); backdrop-filter:blur(24px); border:1px solid rgba(255,255,255,.08); border-radius:20px; padding:24px; transition:all .3s; }
.dashboard-room-card:hover { border-color:rgba(99,102,241,.3); box-shadow:0 8px 32px rgba(99,102,241,.15); transform:translateY(-3px); }
.dashboard-room-header { display:flex; align-items:center; gap:14px; margin-bottom:16px; }
.dashboard-room-icon { width:44px; height:44px; border-radius:12px; background:linear-gradient(135deg,#4f46e5,#7c3aed); display:flex; align-items:center; justify-content:center; color:white; flex-shrink:0; }
.dashboard-room-meta { display:flex; flex-direction:column; gap:2px; min-width:0; }
.dashboard-room-name { font-size:1.05rem; font-weight:700; color:white; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dashboard-room-role { font-size:.7rem; color:#a5b4fc; font-weight:600; text-transform:uppercase; letter-spacing:.05em; }
.dashboard-room-details { display:flex; flex-direction:column; gap:8px; margin-bottom:18px; }
.dashboard-room-detail { display:flex; align-items:center; gap:8px; font-size:.8rem; color:rgba(255,255,255,.5); }
.dashboard-room-id { font-family:monospace; color:rgba(255,255,255,.7); font-weight:500; }
.dashboard-copy-btn { background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1); border-radius:6px; padding:3px 6px; color:rgba(255,255,255,.5); cursor:pointer; transition:all .2s; display:flex; }
.dashboard-copy-btn:hover { background:rgba(255,255,255,.12); color:white; }
.dashboard-room-enter { width:100%; padding:12px; border-radius:12px; background:rgba(99,102,241,.12); border:1px solid rgba(99,102,241,.2); color:#a5b4fc; font-weight:600; font-size:.85rem; cursor:pointer; transition:all .25s; display:flex; align-items:center; justify-content:center; gap:8px; }
.dashboard-room-enter:hover { background:rgba(99,102,241,.2); color:#c7d2fe; transform:translateY(-1px); }

.dashboard-footer { position:relative; z-index:10; text-align:center; padding:20px; font-size:.75rem; color:rgba(255,255,255,.2); border-top:1px solid rgba(255,255,255,.05); }

@media (max-width:768px) {
  .profile-avatar-section { flex-direction:column; text-align:center; padding:28px 24px; }
  .profile-avatar-info { align-items:center; }
  .profile-fields { padding:20px 24px; }
  .profile-actions { padding:16px 24px 24px; }
  .dashboard-rooms-grid { grid-template-columns:1fr; }
  .dashboard-nav-inner { flex-wrap:wrap; gap:12px; }
  .dashboard-header { flex-direction:column; align-items:stretch; }
  .dashboard-create-btn { width:100%; justify-content:center; }
}

/* ═══════════════════════════════════════════════
   Interactive Room Styles (US-06 / TS-02)
   ═══════════════════════════════════════════════ */
.room-status-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  background: #0d0c15;
  color: white;
  box-sizing: border-box;
}

.room-status-card {
  position: relative;
  z-index: 10;
  max-width: 440px;
  width: 100%;
  margin: 20px;
  padding: 40px 32px;
  background: rgba(20, 18, 42, 0.65);
  backdrop-filter: blur(28px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24px;
  text-align: center;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  animation: auth-slide-up 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.room-spinner {
  color: #6366f1;
  animation: spin 1s linear infinite;
  margin-bottom: 24px;
}

.room-status-card h2 {
  font-size: 1.4rem;
  font-weight: 750;
  margin: 0 0 10px;
}

.room-status-card p {
  font-size: 0.9rem;
  color: rgba(255, 255, 255, 0.5);
  margin: 0;
}

.room-status-card--error {
  border-color: rgba(239, 68, 68, 0.25);
  box-shadow: 0 20px 50px rgba(239, 68, 68, 0.1);
}

.room-error-icon {
  color: #ef4444;
  margin-bottom: 20px;
  animation: float-orb-1 5s ease-in-out infinite alternate;
}

.room-error-btn {
  width: 100%;
  padding: 14px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.12);
  color: white;
  font-weight: 650;
  cursor: pointer;
  margin-top: 24px;
  transition: all 0.25s;
}

.room-error-btn:hover {
  background: rgba(255, 255, 255, 0.16);
  transform: translateY(-1px);
}

/* Full Room Screen Layout */
.room-page {
  min-height: 100vh;
  background: #06050b;
  color: white;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}

.room-header {
  position: relative;
  z-index: 10;
  background: rgba(13, 12, 28, 0.6);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  padding: 16px 28px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.room-header-left {
  display: flex;
  align-items: center;
  gap: 16px;
}

.room-logo {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  box-shadow: 0 4px 16px rgba(99, 102, 241, 0.35);
}

.room-title-wrap {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.room-name-text {
  font-size: 1.15rem;
  font-weight: 750;
  color: white;
  margin: 0;
}

.room-badge-row {
  display: flex;
  align-items: center;
  gap: 8px;
}

.room-id-badge {
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.55);
