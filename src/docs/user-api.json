{
  "openapi": "3.0.3",
  "info": {
    "title": "User API - MP2",
    "description": "API de autenticación y gestión de usuarios para MP2 (Meet Clone).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor de desarrollo local"
    }
  ],
  "paths": {
    "/register": {
      "post": {
        "tags": ["Usuario"],
        "summary": "Registrar un nuevo usuario",
        "description": "Crea un usuario con email, contraseña y datos personales.",
        "operationId": "registerUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterData"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Usuario registrado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Datos inválidos o usuario ya existente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": ["Usuario"],
        "summary": "Iniciar sesión",
        "description": "Autentica al usuario con username (o email) y contraseña.",
        "operationId": "loginUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Inicio de sesión exitoso",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Credenciales inválidas",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/google-login": {
      "post": {
        "tags": ["Usuario"],
        "summary": "Iniciar sesión con Google",
        "description": "Recibe los datos del usuario autenticado con Google desde el frontend y lo guarda/verifica en Firestore.",
        "operationId": "googleLogin",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleLoginData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Usuario autenticado con Google",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GoogleAuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Error al procesar el login con Google",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/google-register-complete": {
      "post": {
        "tags": ["Usuario"],
        "summary": "Completar registro de Google con username",
        "description": "Asigna un username único al usuario que se registró con Google.",
        "operationId": "googleRegisterComplete",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleRegisterCompleteData"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Perfil completado exitosamente",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Username no disponible o datos inválidos",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": ["Usuario"],
        "summary": "Cerrar sesión",
        "description": "Cierra la sesión del usuario en Firebase y notifica al backend.",
        "operationId": "logoutUser",
        "responses": {
          "200": {
            "description": "Sesión cerrada exitosamente"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterData": {
        "type": "object",
        "required": ["username", "password", "email", "name", "surname"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Nombre de usuario único"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Contraseña del usuario"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Correo electrónico"
          },
          "name": {
            "type": "string",
            "description": "Nombre del usuario"
          },
          "surname": {
            "type": "string",
            "description": "Apellido del usuario"
          }
        }
      },
      "LoginData": {
        "type": "object",
        "required": ["username", "password"],
        "properties": {
          "username": {
            "type": "string",
            "description": "Nombre de usuario (o email) para iniciar sesión"
          },
          "password": {
            "type": "string",
            "format": "password",
            "description": "Contraseña del usuario"
          }
        }
      },
      "GoogleLoginData": {
        "type": "object",
        "required": ["uid", "email"],
        "properties": {
          "uid": {
            "type": "string",
            "description": "UID de Firebase Authentication"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Correo electrónico del usuario de Google"
          },
          "displayName": {
            "type": "string",
            "description": "Nombre público del usuario de Google"
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "description": "URL de la foto de perfil de Google"
          }
        }
      },
      "GoogleRegisterCompleteData": {
        "type": "object",
        "required": ["uid", "email", "username"],
        "properties": {
          "uid": {
            "type": "string",
            "description": "UID de Firebase Authentication"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Correo electrónico del usuario"
          },
          "displayName": {
            "type": "string",
            "description": "Nombre público del usuario"
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "description": "URL de la foto de perfil"
          },
          "username": {
            "type": "string",
            "description": "Nombre de usuario único a asignar"
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "uid": {
            "type": "string",
            "description": "UID de Firebase Authentication"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Correo electrónico"
          },
          "displayName": {
            "type": "string",
            "description": "Nombre público"
          },
          "photoURL": {
            "type": "string",
            "format": "uri",
            "description": "URL de la foto de perfil"
          },
          "username": {
            "type": "string",
            "description": "Nombre de usuario único"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "description": "Mensaje de la operación"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "GoogleAuthResponse": {
        "type": "object",
        "properties": {
          "isNewUser": {
            "type": "boolean",
            "description": "Indica si el usuario es nuevo o ya existía"
          },
          "message": {
            "type": "string",
            "description": "Mensaje de la operación"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Mensaje de error"
          }
        }
      }
    }
  }
}